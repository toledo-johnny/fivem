/*
!/.gitignore
!/README.md
!/bd.sql
!/base-fivem/
!/base-fivem/**
!/bot-discord/
!/bot-discord/**
!/.github/
!/.github/**
!/deploy/
!/deploy/**
!/web-sistema/
!/web-sistema/**

# Nested repositories
**/.git/

# Local secrets
base-fivem/server/server.secrets.cfg
bot-discord/.env*
web-sistema/.env*

# Dependencies and build artifacts
base-fivem/artifacts/
base-fivem/server/.replxx_history
base-fivem/server/cache/
base-fivem/server/txData/
base-fivem/server/*.log
**/node_modules/
**/dist/
**/build/
**/coverage/
**/.runtime/
**/*.log
**/.DS_Store

# Keep tracked examples
!bot-discord/.env.example
!web-sistema/.env.example
