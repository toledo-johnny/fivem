{
  "name": "fivem-discord-bot",
  "version": "2.0.0",
  "private": true,
  "description": "Bot unificado de tickets, whitelist e status FiveM para servidores RP.",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "start": "npm run start:bot",
    "start:bot": "node ./src/index.js",
    "start:api": "node ./src/api.js",
    "start:bot:localhost": "node ./src/scripts/runRuntime.js .env.localhost ./src/index.js",
    "start:api:localhost": "node ./src/scripts/runRuntime.js .env.localhost ./src/api.js",
    "start:bot:vps": "node ./src/scripts/runRuntime.js .env.vps ./src/index.js",
    "start:api:vps": "node ./src/scripts/runRuntime.js .env.vps ./src/api.js",
    "dev": "npm run dev:bot",
    "dev:bot": "nodemon ./src/index.js",
    "dev:api": "nodemon ./src/api.js",
    "deploy:commands": "node ./src/scripts/deployCommands.js",
    "check": "npm run check:env && npm run test && npm run check:syntax",
    "check:env": "node ./src/scripts/validateEnv.js",
    "check:env:localhost": "node ./src/scripts/runRuntime.js .env.localhost ./src/scripts/validateEnv.js",
    "check:env:vps": "node ./src/scripts/runRuntime.js .env.vps ./src/scripts/validateEnv.js",
    "check:syntax": "node ./src/scripts/checkSyntax.js",
    "test": "node ./src/scripts/runTests.js"
  },
  "dependencies": {
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "discord.js": "^14.25.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "mysql2": "^3.16.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
